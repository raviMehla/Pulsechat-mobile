{
  "expo": {
    "name": "PulseChat",
    "slug": "pulse-chat",
    "scheme": "msgapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B0F",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pulsechat.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "PulseChat uses your camera to take photos and videos to share.",
        "NSMicrophoneUsageDescription": "PulseChat uses your microphone to record voice messages and make calls.",
        "NSPhotoLibraryUsageDescription": "PulseChat uses your photo library to share images.",
        "NSContactsUsageDescription": "PulseChat uses your contacts to help you find friends."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0B0B0F"
      },
      "package": "com.pulsechat.mobile",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "PulseChat needs access to your photos to share images.",
          "cameraPermission": "PulseChat needs camera access to take photos."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "PulseChat uses your camera to take photos and videos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#7C6EF7",
          "defaultChannel": "messages"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "PulseChat needs microphone access to record voice messages."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0B0F",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "9eddbdb4-7aa4-4bb6-ab57-a42c755fa359"
      }
    }
  }
}
